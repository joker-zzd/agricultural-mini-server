        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mini.points.mapper.PointsRecordMapper">

    <resultMap id="BaseResultMap" type="com.mini.points.domain.PointsRecord">
            <id property="id" column="id" jdbcType="BIGINT"/>
